meta {
  name: Create Project
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/projects
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "My New Project",
    "description": "Created via Bruno"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("projectId", res.body.id);
  }
}
