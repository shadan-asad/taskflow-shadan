meta {
  name: Create Task
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/projects/{{projectId}}/tasks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "Build login page",
    "description": "Implement JWT-based login",
    "priority": "high",
    "due_date": "2025-12-31"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("taskId", res.body.id);
  }
}
